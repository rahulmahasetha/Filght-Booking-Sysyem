{
  "version": 2,
  "builds": [
    {
      "src": "Filght-Booking-Sysyem-main/myproject/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.12",
        "missingFrameworkWarning": false
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "Filght-Booking-Sysyem-main/myproject/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "myproject.settings",
    "PYTHONUNBUFFERED": "1"
  }
}
